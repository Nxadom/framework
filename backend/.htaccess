# ═══════════════════════════════════════════════════════════════════════════════
# PHP Upload Limits (Apache mod_php)
# Untuk PHP-FPM, lihat .user.ini di root
# ═══════════════════════════════════════════════════════════════════════════════
<IfModule mod_php.c>
    php_value upload_max_filesize 512M
    php_value post_max_size 512M
    php_value memory_limit 512M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 512M
    php_value post_max_size 512M
    php_value memory_limit 512M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

RewriteCond %{REQUEST_URI} ^/rebit [NC]
# Nonaktifkan daftar direktori
Options -Indexes

# Aktifkan penulisan ulang URL
RewriteEngine On

# Blokir akses langsung ke folder sensitif
RewriteRule ^(controllers|models|system|vendor)/ - [F,L]

# Izinkan akses ke file JavaScript dan CSS dalam templates directory
RewriteRule ^templates/.*\.(js|css|png|jpg|jpeg|gif|svg)$ - [L]

# Blokir akses ke file media lainnya dalam templates directory
RewriteRule ^templates/.*\.(png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$ - [F,L]

# Blokir akses langsung ke view templates (PHP, HTML files) dalam views
RewriteRule ^templates/.*\.(php|html|htm|tpl)$ - [F,L]

# Blokir akses ke views directory tanpa file extension (folder browsing)
RewriteRule ^templates/$ - [F,L]

# Atur direktori dasar untuk aturan penulisan ulang

# Redirect favicon.ico requests ke favicon.png di assets
RewriteRule ^favicon\.ico$ assets/images/favicon.png [L]

# ═══════════════════════════════════════════════════════════════════════════════
# CLEAN URL ROUTES: Route to Controllers (NOT direct file access)
# IMPORTANT: /drive and /images must go through PHP controllers for resize support
# ═══════════════════════════════════════════════════════════════════════════════

# ── Aset statis: Apache langsung (tanpa index.php / bootstrap Nexa) ─────────────

# /modules/* → assets/modules/* (nexa.css + puluhan @import)
RewriteCond %{REQUEST_URI} ^/modules/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/assets/modules/%1 -f
RewriteRule ^modules/(.+)$ assets/modules/$1 [L]

# ── /assets/* — resolusi template aktif langsung di server, meniru urutan   ────
# ── fallback TemplateController::assets() (cookie nexa_template → UA → theme) ──
# Semua RewriteCond blok ini dibatasi hanya untuk request /assets/* (REQUEST_URI)

# Deteksi template aktif dari cookie nexa_template (di-set PHP saat render halaman)
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteCond %{HTTP_COOKIE} nexa_template=(theme|mobile|tablet|dashboard) [NC]
RewriteRule ^ - [E=NEXA_TPL:%1]

# Tanpa cookie valid: deteksi ringan dari User-Agent (tablet dulu, lalu mobile)
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteCond %{HTTP_COOKIE} !nexa_template=(theme|mobile|tablet|dashboard) [NC]
RewriteCond %{HTTP_USER_AGENT} tablet|ipad|playbook|silk|kindle [NC]
RewriteRule ^ - [E=NEXA_TPL:tablet]

RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteCond %{HTTP_COOKIE} !nexa_template=(theme|mobile|tablet|dashboard) [NC]
RewriteCond %{HTTP_USER_AGENT} !tablet|ipad|playbook|silk|kindle [NC]
RewriteCond %{HTTP_USER_AGENT} Mobile|Android|webOS|iPhone|iPod|BlackBerry|IEMobile|Opera\ Mini [NC]
RewriteRule ^ - [E=NEXA_TPL:mobile]

# Default (tidak ada cookie, UA desktop): theme
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteCond %{HTTP_COOKIE} !nexa_template=(theme|mobile|tablet|dashboard) [NC]
RewriteCond %{HTTP_USER_AGENT} !tablet|ipad|playbook|silk|kindle [NC]
RewriteCond %{HTTP_USER_AGENT} !(Mobile|Android|webOS|iPhone|iPod|BlackBerry|IEMobile|Opera\ Mini) [NC]
RewriteRule ^ - [E=NEXA_TPL:theme]

# 1) templates/{template-aktif}/assets/*
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/templates/%{ENV:NEXA_TPL}/assets/%1 -f
RewriteRule ^assets/(.+)$ templates/%{ENV:NEXA_TPL}/assets/$1 [L]

# 2) fallback: templates/theme/assets/* (theme = default project-wide)
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/templates/theme/assets/%1 -f
RewriteRule ^assets/(.+)$ templates/theme/assets/$1 [L]

# 3) fallback: templates/mobile/assets/*
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/templates/mobile/assets/%1 -f
RewriteRule ^assets/(.+)$ templates/mobile/assets/$1 [L]

# 4) fallback: templates/tablet/assets/*
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/templates/tablet/assets/%1 -f
RewriteRule ^assets/(.+)$ templates/tablet/assets/$1 [L]

# 5) fallback: templates/dashboard/assets/*
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/templates/dashboard/assets/%1 -f
RewriteRule ^assets/(.+)$ templates/dashboard/assets/$1 [L]

# 6) fallback terakhir: assets/* di root proyek (gambar global, dll.)
RewriteCond %{REQUEST_URI} ^/assets/(.+)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/assets/%1 -f
RewriteRule ^assets/(.+)$ assets/$1 [L]

# Tidak ditemukan di manapun secara fisik: serahkan ke PHP (TemplateController::assets)
RewriteRule ^assets/(.*)$ index.php [QSA,L]

# Jika file atau direktori yang diminta ada (EXCEPT /drive and /images routes)
# Allow direct access to physical files, but route /drive and /images to controllers
RewriteCond %{REQUEST_URI} !^/[^/]*/drive/
RewriteCond %{REQUEST_URI} !^/[^/]*/images/
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route ALL other requests (including /drive and /images) to index.php
# This allows DriveController and ImagesController to handle requests with resize support
RewriteRule ^(.*)$ index.php [QSA,L]


#RewriteEngine On
#RewriteCond %{HTTPS} off
#RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]