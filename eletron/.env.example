# Salin ke `.env` dan sesuaikan.

# Windows: pisahkan ikon taskbar antar app Electron (wajib unik per produk).
# Saat build installer, samakan dengan build.appId di package.json.
# ELECTRON_APP_ID=com.eletron.flowmusic

# Geolocation (navigator.geolocation) di Electron — tanpa kunci sering 403 di DevTools.
# https://www.electronjs.org/docs/latest/api/environment-variables#google_api_key
# GOOGLE_API_KEY=
